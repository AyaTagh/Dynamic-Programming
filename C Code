#include <stdio.h>
#include <string.h>
#include <time.h>

#define MAX 100

int max(int a, int b) {
    return (a > b) ? a : b;
}

int lcs_recursive(char X[], char Y[], int n, int m) {
    if (n == 0 || m == 0)
        return 0;

    if (X[n - 1] == Y[m - 1])
        return 1 + lcs_recursive(X, Y, n - 1, m - 1);

    return max(
        lcs_recursive(X, Y, n - 1, m),
        lcs_recursive(X, Y, n, m - 1)
    );
}

int lcs_dp(char X[], char Y[], int n, int m) {
    int dp[MAX][MAX];

    for (int i = 0; i <= n; i++)
        dp[i][0] = 0;

    for (int j = 0; j <= m; j++)
        dp[0][j] = 0;

    for (int i = 1; i <= n; i++) {
        for (int j = 1; j <= m; j++) {
            if (X[i - 1] == Y[j - 1])
                dp[i][j] = 1 + dp[i - 1][j - 1];
            else
                dp[i][j] = max(dp[i - 1][j], dp[i][j - 1]);
        }
    }

    return dp[n][m];
}

int main() {
    char X[] = "ABCDEFGHIJ";
    char Y[] = "ACEGIKLMNO";

    int n = strlen(X);
    int m = strlen(Y);

    clock_t start, end;
    double cpu_time;

    start = clock();
    int result_recursive = lcs_recursive(X, Y, n, m);
    end = clock();

    cpu_time = ((double)(end - start)) / CLOCKS_PER_SEC;

    printf("Recursive LCS length: %d\n", result_recursive);
    printf("Recursive execution time: %f seconds\n\n", cpu_time);

    start = clock();
    int result_dp = lcs_dp(X, Y, n, m);
    end = clock();

    cpu_time = ((double)(end - start)) / CLOCKS_PER_SEC;

    printf("DP LCS length: %d\n", result_dp);
    printf("DP execution time: %f seconds\n", cpu_time);

    return 0;
}
